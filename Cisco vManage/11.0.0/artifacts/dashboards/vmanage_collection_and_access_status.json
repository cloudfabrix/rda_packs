{
    "name": "vmanage_collection_and_access_status",
    "label": "vManage Performance Collection Status",
    "description": "vManage collection and access verification status",
    "dashboard_folder": "VmanageInventory",
    "version": "26.06.19.1",
    "enabled": true,
    "dashboard_type": "template",
    "template_variables": {
        "CUST_ID": {
            "contextId": "customerId"
        },
        "PROJ_ID": {
            "contextId": "projectId"
        },
        "CUST_TAG": {
            "contextId": "customerTag"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "extra_filter": "(customer_tag is '{{CUST_TAG}}' or customer_tag is empty or customer_tag is '' or customer_tag is 'None')",
        "default_time_filter_labels": [
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days"
        ],
        "columns_filter": [
            {
                "id": "collection_status",
                "label": "Collection Status",
                "type": "TEXT"
            },
            {
                "id": "bot_source_type",
                "label": "Source Type",
                "type": "TEXT"
            }
        ]
    },
    "dashboard_sections": [
        {
            "title": "Access Verifcation Status",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Access Verifcation Status",
                    "widget_type": "tabular",
                    "stream": "vmanage_access_verification_status_stream",
                    "ts_column": "timestamp",
                    "height": 4,
                    "max_width": 12,
                    "min_width": 12,
                    "columns": {
                        "asset_id": {
                            "title": "Asset Name",
                            "type": "TEXT",
                            "visible": true
                        },
                        "timestamp": {
                            "title": "Verification Time",
                            "type": "DATETIME",
                            "visible": true
                        },
                        "collection_status": {
                            "title": "Status",
                            "htmlTemplateForRow": "{%raw%}<span class='badge' style='background-color: {{ row.status_color }}' > {{ row.collection_status }} </span>{%endraw%}"
                        },
                        "bot_source_name": {
                            "title": "Credential Used"
                        },
                        "bot_name": {
                            "title": "Bot Name",
                            "visible": false
                        },
                        "reason": {
                            "title": "Failure Reason"
                        }
                    },
                    "custom_columns": [
                        {
                            "id": "status_color",
                            "label": "Discovery Scope Color",
                            "key": false,
                            "visible": false,
                            "expr": "'#22C55E' if collection_status == 'Success' else '#EF4444'"
                        }
                    ],
                    "widget_id": "b2c8d81c"
                }
            ]
        },
        {
            "title": "Collection Status",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Collection Status",
                    "widget_type": "tabular",
                    "stream": "asset_inventory_collection_status_stream",
                    "extra_filter": "bot_source_type in ['vManage','cisco-vmanage']",
                    "ts_column": "collection_timestamp",
                    "height": 4,
                    "max_width": 12,
                    "min_width": 12,
                    "columns": {
                        "asset_id": {
                            "title": "Asset",
                            "type": "TEXT",
                            "visible": true
                        },
                        "collection_timestamp": {
                            "title": "Collection time",
                            "type": "DATETIME",
                            "visible": true
                        },
                        "collection_status": {
                            "title": "Status",
                            "htmlTemplateForRow": "{%raw%}<span class='badge' style='background-color: {{ row.status_color }}' > {{ row.collection_status }} </span>{%endraw%}"
                        },
                        "bot_source_name": {
                            "title": "Bot Source Name"
                        },
                        "bot_source_type": {
                            "title": "Bot Source Type"
                        },
                        "bot_name": {
                            "title": "Bot Name"
                        },
                        "reason": {
                            "title": "Failure Reason"
                        }
                    },
                    "custom_columns": [
                        {
                            "id": "status_color",
                            "label": "Discovery Scope Color",
                            "key": false,
                            "visible": false,
                            "expr": "'#22C55E' if collection_status == 'Success' else '#EF4444'"
                        }
                    ],
                    "widget_id": "b585247a"
                }
            ]
        }
    ],
    "live_edit": true,
    "stream": "asset_inventory_collection_status_stream",
    "saved_time": "2026-06-22T07:17:58.608257"
}