                            "query": "topology_source is 'cisco_vmanage' and node_type in ['vedge','vmanage','vbond','vsmart'] and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty or customer_tag is '' or customer_tag is 'None')"
