        {
            "name": "style.css",
            "value": "body {\r\n  background: #f3f4f6;\r\n  font-family: \"Inter\", Arial, sans-serif;\r\n  margin: 0;\r\n}\r\n\r\n/* Modal overlay */\r\n.modal {\r\n  position: fixed;\r\n  inset: 0;\r\n  background: rgba(0, 0, 0, 0.35);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n/* Modal container */\r\n.modal-content {\r\n  width: 900px;\r\n  max-height: 90vh;\r\n  background: #f9fafb;\r\n  border-radius: 12px;\r\n  box-shadow: 0 10px 30px rgba(0,0,0,0.25);\r\n  display: flex;\r\n  flex-direction: column;\r\n  overflow: hidden;\r\n}\r\n\r\n/* Header */\r\n.modal-header {\r\n  padding: 16px 20px;\r\n  font-size: 16px;\r\n  font-weight: 600;\r\n  color: #111827;\r\n  border-bottom: 1px solid #e5e7eb;\r\n}\r\n\r\n/* Body */\r\n.modal-body {\r\n  padding: 16px 20px;\r\n  overflow-y: auto;\r\n}\r\n\r\n/* Form rows */\r\n.form-group {\r\n  margin-bottom: 14px;\r\n  position: relative;\r\n}\r\n\r\n/* Labels */\r\nlabel {\r\n  display: block;\r\n  font-size: 13px;\r\n  color: #6b7280;\r\n  margin-bottom: 6px;\r\n}\r\n\r\n/* Inputs */\r\ninput,\r\nselect,\r\ntextarea {\r\n  width: 100%;\r\n  padding: 10px 12px;\r\n  border: 1px solid #d1d5db;\r\n  border-radius: 8px;\r\n  font-size: 14px;\r\n  background: #ffffff;\r\n  transition: all 0.2s ease;\r\n}\r\n\r\n/* Focus state (important) */\r\ninput:focus,\r\nselect:focus,\r\ntextarea:focus {\r\n  outline: none;\r\n  border-color: #3b82f6;\r\n  box-shadow: 0 0 0 2px rgba(59,130,246,0.15);\r\n}\r\n\r\n/* Placeholder */\r\ninput::placeholder,\r\ntextarea::placeholder {\r\n  color: #9ca3af;\r\n}\r\n\r\n/* Right-side info icon */\r\n.info-icon {\r\n  position: absolute;\r\n  right: 10px;\r\n  top: 34px;\r\n  font-size: 14px;\r\n  color: #3b82f6;\r\n  cursor: pointer;\r\n}\r\n\r\n/* Footer */\r\n.modal-footer {\r\n  padding: 12px 20px;\r\n  border-top: 1px solid #e5e7eb;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 10px;\r\n  background: #f9fafb;\r\n}\r\n\r\n/* Buttons */\r\nbutton {\r\n  padding: 8px 16px;\r\n  border-radius: 8px;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  border: 1px solid transparent;\r\n}\r\n\r\n/* Primary button */\r\nbutton.primary {\r\n  background: #60a5fa;\r\n  color: white;\r\n}\r\n\r\nbutton.primary:hover {\r\n  background: #3b82f6;\r\n}\r\n\r\n/* Secondary */\r\nbutton.secondary {\r\n  background: #ffffff;\r\n  border-color: #d1d5db;\r\n  color: #374151;\r\n}\r\n\r\nbutton.secondary:hover {\r\n  background: #f3f4f6;\r\n}",
