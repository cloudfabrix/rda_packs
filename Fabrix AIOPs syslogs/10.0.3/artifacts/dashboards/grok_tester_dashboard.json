        {
            "name": "main.html",
            "value": "<!DOCTYPE html>\r\n<html>\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <title>Advanced Grok Tester</title>\r\n  <link rel=\"stylesheet\" href=\"style.css\">\r\n</head>\r\n\r\n<body>\r\n\r\n<h2>Grok Pattern </h2>\r\n\r\n<div class=\"container\">\r\n\r\n  <div class=\"panel\">\r\n    <label>Grok Rules</label>\r\n    <textarea id=\"rules\">{{grok}}</textarea>\r\n  </div>\r\n\r\n  <div class=\"panel\">\r\n    <label>Sample Logs</label>\r\n    <textarea id=\"sample\">\r\n    </textarea>\r\n  </div>\r\n\r\n  <div class=\"panel\">\r\n    <label>Parsed Output</label>\r\n    <pre id=\"output\"></pre>\r\n  </div>\r\n\r\n</div>\r\n\r\n<div class=\"actions\">\r\n  <button onclick=\"runParser()\">Parse</button>\r\n  <button onclick=\"clearOutput()\">Clear</button>\r\n</div>\r\n\r\n<script>\r\n\r\n/* ------------------------------\r\n   GROK PATTERN LIBRARY\r\n------------------------------ */\r\nconst grokPatterns = {\r\n  WORD: \"[^\\\\s]+\",\r\n  NUMBER: \"\\\\d+\",\r\n  INT: \"\\\\d+\",\r\n  IP: \"\\\\b(?:\\\\d{1,3}\\\\.){3}\\\\d{1,3}\\\\b\",\r\n  HOSTNAME: \"[a-zA-Z0-9._-]+\",\r\n  DATA: \".*?\",\r\n  GREEDYDATA: \".*\",\r\n  NOTSPACE: \"\\\\S+\",\r\n  MONTH: \"[A-Z][a-z]{2}\",\r\n  MONTHDAY: \"\\\\d{1,2}\",\r\n  TIME: \"\\\\d{2}:\\\\d{2}:\\\\d{2}\",\r\n  SYSLOGTIMESTAMP: \"[A-Z][a-z]{2}\\\\s+\\\\d{1,2}\\\\s\\\\d{2}:\\\\d{2}:\\\\d{2}\",\r\n  IPORHOST: \"(?:\\\\b(?:\\\\d{1,3}\\\\.){3}\\\\d{1,3}\\\\b|[a-zA-Z0-9._-]+)\"\r\n};\r\n\r\n/* ------------------------------\r\n   GROK \u2192 REGEX\r\n------------------------------ */\r\nfunction grokToRegex(pattern) {\r\n  let fieldNames = [];\r\n\r\n  let regexStr = pattern.replace(/%{(\\w+):(\\w+)}/g, (match, type, name) => {\r\n\r\n    if (!grokPatterns[type]) {\r\n      console.warn(\"Unknown pattern:\", type);\r\n      fieldNames.push(name);\r\n      return \"(.*?)\";\r\n    }\r\n\r\n    fieldNames.push(name);\r\n    return `(${grokPatterns[type]})`;\r\n  });\r\n\r\n  return {\r\n    regex: new RegExp(regexStr),\r\n    fields: fieldNames\r\n  };\r\n}\r\n\r\n/* ------------------------------\r\n   MATCH ONE LINE\r\n------------------------------ */\r\nfunction matchLine(line, rules) {\r\n  for (let pattern of rules) {\r\n    try {\r\n      const { regex, fields } = grokToRegex(pattern);\r\n      const match = line.match(regex);\r\n\r\n      if (match) {\r\n        let obj = { matched_rule: pattern };\r\n\r\n        fields.forEach((f, i) => {\r\n          obj[f] = match[i + 1];\r\n        });\r\n\r\n        return obj;\r\n      }\r\n\r\n    } catch (e) {}\r\n  }\r\n\r\n  return { error: \"No match\", raw: line };\r\n}\r\n\r\n/* ------------------------------\r\n   MAIN PARSER\r\n------------------------------ */\r\nfunction runParser() {\r\n\r\n  const rules = document.getElementById(\"rules\")\r\n    .value.split(\"\\n\")\r\n    .map(r => r.trim())\r\n    .filter(Boolean);\r\n\r\n  const sample = document.getElementById(\"sample\").value;\r\n  const output = document.getElementById(\"output\");\r\n\r\n  const lines = sample\r\n    .split(/\\r?\\n/)\r\n    .map(l => l.trim())\r\n    .filter(Boolean);\r\n\r\n  let results = lines.map(line => matchLine(line, rules));\r\n\r\n  output.innerText = JSON.stringify(results, null, 2);\r\n}\r\n\r\n/* ------------------------------ */\r\nfunction clearOutput() {\r\n  document.getElementById(\"output\").innerText = \"\";\r\n}\r\n\r\n/* ------------------------------\r\n   LOAD GROK FROM CONTEXT\r\n------------------------------ */\r\nfunction loadGrokFromContext() {\r\n    try {\r\n        const ctx = window; // or however you're accessing context\r\n\r\n        const grok = getGrokFromContext(ctx);\r\n\r\n        if (!grok) {\r\n            console.error(\"\u274c Grok not found in contextIdList\");\r\n            return null;\r\n        }\r\n\r\n        console.log(\"\u2705 Grok loaded:\", grok);\r\n\r\n        return grok;\r\n\r\n    } catch (e) {\r\n        console.error(\"\u274c Error loading grok:\", e);\r\n        return null;\r\n    }\r\n}\r\n\r\nwindow.onload = loadGrokFromContext;\r\n\r\nwindow.onload = loadGrokFromContext;\r\n\r\n</script>\r\n\r\n</body>\r\n</html>",
            "additionalFields": {
                "valueType": "",
                "description": ""
            }
        }
    ]
