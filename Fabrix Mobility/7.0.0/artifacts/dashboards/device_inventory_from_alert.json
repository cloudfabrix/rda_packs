{
    "name": "device_inventory_from_alert",
    "label": "Inventory",
    "description": "Device Inventory",
    "dashboard_folder": "MSP",
    "version": "26.01.21.1",
    "enabled": false,
    "stream": "network-devices-inventory",
    "dashboard_type": "template",
    "template_variables": {
        "CUST_ID": {
            "contextId": "customerId"
        },
        "PROJ_ID": {
            "contextId": "projectId"
        },
        "CUST_TAG": {
            "contextId": "customerTag"
        },
        "SERIAL_NUM": {
            "contextId": "parent_serial_number"
        },
        "DEVICE_SERIAL_NUM": {
            "contextId": "serial_number"
        },
        "DEVICE_IP": {
            "contextId": "a_asset_ip_address"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "extra_filter0": "(a_asset_ip_address is '{{DEVICE_IP}}' or a_asset_name is '{{DEVICE_IP}}') ",
        "default_time_filter_labels": [
            "Last 24 hours"
        ],
        "columns_filter": [
            {
