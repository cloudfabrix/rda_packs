            },
            {
                "id": "interface_oper_status_label",
                "label": "Operational Status",
                "type": "TEXT"
            },
            {
                "id": "interface_admin_status_label",
                "label": "Admin Status",
                "type": "TEXT"
            },
            {
                "id": "device_int_in_octets",
                "label": "ifHCInOctets",
                "type": "TEXT"
            },
            {
                "id": "device_int_out_octets",
                "label": "ifHCOutOctets",
                "type": "TEXT"
            },
            {
                "id": "timestamp",
                "label": "Timestamp",
                "type": "DATETIME"
            },
            {
                "id": "delta",
                "label": "Last Polled",
                "type": "HUMANIZE_TIME_DELTA"
            },
            {
                "id": "customerId",
                "label": "Customer ID",
                "type": "TEXT"
            },
            {
                "id": "projectId",
                "label": "Project ID",
                "type": "TEXT"
            },
            {
                "id": "customerTag",
                "label": "Customer",
                "type": "TEXT"
            },
            {
                "id": "ip_address",
                "label": "Device IP",
                "type": "TEXT"
            },
            {
                "id": "hostname",
                "label": "Device Hostname",
