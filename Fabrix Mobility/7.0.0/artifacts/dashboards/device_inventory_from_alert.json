            },
            {
                "id": "device_model",
                "label": "Device Model",
                "type": "TEXT"
            },
            {
                "id": "serial_number",
                "label": "Device Serial Number",
                "type": "TEXT"
            },
            {
                "id": "vendor",
                "label": "Device Vendor",
                "type": "TEXT"
            },
            {
                "id": "interface_name",
                "label": "Device Interface Name",
                "type": "TEXT"
            },
            {
                "id": "interface_name",
                "label": "Device Interface Short Name",
