          "title": "RP De-registration Requests Received and Accepted",
          "widget_type": "timeseries",
          "stream": "mobility_kpi_metrics_data",
          "description": "Formula: (%accept-dereg%) Description: RP De-registration Requests Received and Accepted",
          "ts_column": "timestamp",
          "max_width": 12,
          "height": 6,
          "min_width": 12,
          "chartProperties": {
            "yAxisLabel": "",
            "xAxisLabel": null,
            "legendLocation": "right",
