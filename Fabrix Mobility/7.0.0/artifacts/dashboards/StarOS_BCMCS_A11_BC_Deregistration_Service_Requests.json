            "column-id": "timestamp"
          },
          "interval": "{{INTERVAL}}",
          "series_spec": [
            {
              "column": "kpi_RP_De_registration_Requests_Received_and_Accepted",
              "agg": "{{FUNCTION}}",
              "type": "int"
            }
          ],
          "extra_filter": "device = '{{DEVICE}}' and schema_key is 'bcmcs'",
          "group_by": [
