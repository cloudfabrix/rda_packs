{
  "name": "StarOS_BCMCS_A11_BC_Deregistration_Service_Requests",
  "label": "StarOS BCMCS A11-BC Deregistration Service Requests",
  "description": "Web report: StarOS BCMCS A11-BC Deregistration Service Requests",
  "dashboard_folder": "mobility-webreport",
  "enabled": true,
  "stream": "mobility_kpi_metrics_data",
  "dashboard_type": "template",
  "template_variables": {
    "DEVICE": {
      "contextId": "device"
    },
    "FUNCTION": {
      "contextId": "function",
      "default": "max"
    },
    "INTERVAL": {
      "contextId": "interval",
      "default": "auto"
    },
    "ROLLUP": {
      "contextId": "rollup",
      "default": "device"
    },
    "SCHEMA": {
      "contextId": "schema",
      "default": "bcmcs"
    }
  },
  "dashboard_filters": {
    "time_filter": true,
    "default_time_filter_labels": [
      "Last 24 hours"
    ]
  },
  "dynamic_form": {
    "formData": {},
    "controlPanelFormDefinition": {
      "id": "kpi.benchmark.json",
      "refreshRequired": true,
      "formFieldList": [
        {
          "fieldId": "function",
          "label": "Function",
          "help": "Function",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": "max",
          "lovValues": [
            {
              "identifier": "max",
              "displayName": "Maximum"
            },
            {
              "identifier": "min",
              "displayName": "Minimum"
            },
            {
              "identifier": "avg",
              "displayName": "Average"
            },
            {
              "identifier": "sum",
              "displayName": "Sum"
            }
          ]
        },
        {
          "fieldId": "interval",
          "label": "Interval",
          "help": "Interval",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": null,
          "lovValues": [
            {
              "identifier": "auto",
              "displayName": "Auto"
            },
            {
              "identifier": "5Min",
              "displayName": "5 Minutes"
            },
            {
              "identifier": "15Min",
              "displayName": "15 Minutes"
            },
            {
              "identifier": "1H",
              "displayName": "1 Hour"
            },
            {
              "identifier": "24H",
              "displayName": "1 Day"
            }
          ]
        },
        {
          "fieldId": "device",
          "label": "Device",
          "help": "Device",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "lovSourceType": "pstream",
          "lovSourceParams": {
            "name": "mobility_kpi_metrics_data",
            "valueColumn": "device",
            "labelColumn": "device",
            "query": "schema_key is 'bcmcs'"
          }
        }
      ],
      "formActionList": {
        "formActions": [
          {
            "api-endpoint": {
              "methodName": "submitForm",
              "parse-output": false,
              "params": [
                {
                  "formData": {},
                  "formId": "kpi.benchmark.json"
                }
              ],
              "service-name": "saas-reports",
              "stringified-params": true
            },
            "actionLabel": "Save",
            "type": "SUBMIT",
            "identifier": "Submit"
          },
          {
            "actionLabel": "Cancel",
            "type": "CANCEL",
            "identifier": "Cancel"
          }
        ]
      }
    }
  },
  "dashboard_sections": [
