{
    "name": "auto-x-3-app",
    "label": "EPC Mobility",
    "description": "Mobility 4G EPC KPI Data Explorer",
    "version": "2026.05.06.01",
    "enabled": true,
    "status_poller": {},
    "dashboard_type": "app",
    "live_edit": true,
    "custom_context": {
        "rda-dashboard-live-edit": true
    },
    "context_enrichment": [
        {
            "dataset": "organizations",
            "enrich_columns": [
                "accedianURL",
                "bpaURL"
            ],
            "query_template": "projectId in $projectId",
            "defaultValues": {}
        }
    ],
    "template_variables": {
        "USERID": {
            "default": "admin@cfx.com",
            "contextId": "USER_ID"
        }
    },
    "dashboard_groups": {
        "group": {
            "icon": "overall.svg",
            "label": "Devices New"
        },
        "groupAlerts": {
            "icon": "alert.svg",
            "label": "Alerts"
        },
        "groupTopo": {
            "icon": "topology.svg",
            "label": "Topology"
        },
        "group1": {
            "icon": "hardware.svg",
            "label": "Inventory"
        },
        "group2": {
            "icon": "overall.svg",
            "label": "Data Collection"
        },
        "group3": {
            "icon": "hardware.svg",
            "label": "Onboarding"
        },
        "StarOs": {
            "icon": "status.svg",
            "label": "Mobility StarOS"
        },
        "model": {
            "icon": "blueprint.svg",
            "label": "Data Model"
        }
    },
    "dashboard_pages": [
        {
            "name": "customer_overview",
            "label": "Overview",
