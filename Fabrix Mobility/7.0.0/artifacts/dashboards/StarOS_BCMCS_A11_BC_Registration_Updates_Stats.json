{
  "name": "StarOS_BCMCS_A11_BC_Registration_Updates_Stats",
  "label": "StarOS BCMCS A11-BC Registration Updates Stats",
  "description": "Web report: StarOS BCMCS A11-BC Registration Updates Stats",
  "dashboard_folder": "mobility-webreport",
  "enabled": true,
  "stream": "mobility_kpi_metrics_data",
  "dashboard_type": "template",
  "template_variables": {
    "DEVICE": {
      "contextId": "device"
    },
    "FUNCTION": {
      "contextId": "function",
      "default": "max"
    },
    "INTERVAL": {
      "contextId": "interval",
      "default": "auto"
    },
    "ROLLUP": {
      "contextId": "rollup",
      "default": "device"
    },
    "SCHEMA": {
      "contextId": "schema",
      "default": "bcmcs"
    }
  },
  "dashboard_filters": {
    "time_filter": true,
    "default_time_filter_labels": [
      "Last 24 hours"
    ]
  },
  "dynamic_form": {
    "formData": {},
    "controlPanelFormDefinition": {
      "id": "kpi.benchmark.json",
      "refreshRequired": true,
      "formFieldList": [
        {
          "fieldId": "function",
          "label": "Function",
          "help": "Function",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": "max",
          "lovValues": [
            {
              "identifier": "max",
              "displayName": "Maximum"
            },
            {
              "identifier": "min",
              "displayName": "Minimum"
            },
            {
              "identifier": "avg",
              "displayName": "Average"
            },
            {
              "identifier": "sum",
              "displayName": "Sum"
            }
          ]
        },
        {
          "fieldId": "interval",
          "label": "Interval",
          "help": "Interval",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": null,
          "lovValues": [
            {
              "identifier": "auto",
              "displayName": "Auto"
            },
            {
              "identifier": "5Min",
              "displayName": "5 Minutes"
            },
            {
              "identifier": "15Min",
              "displayName": "15 Minutes"
            },
            {
              "identifier": "1H",
              "displayName": "1 Hour"
            },
            {
              "identifier": "24H",
              "displayName": "1 Day"
            }
          ]
        },
        {
          "fieldId": "device",
          "label": "Device",
          "help": "Device",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "lovSourceType": "pstream",
          "lovSourceParams": {
            "name": "mobility_kpi_metrics_data",
            "valueColumn": "device",
            "labelColumn": "device",
            "query": "schema_key is 'bcmcs'"
          }
        }
      ],
      "formActionList": {
        "formActions": [
          {
            "api-endpoint": {
              "methodName": "submitForm",
              "parse-output": false,
              "params": [
                {
                  "formData": {},
                  "formId": "kpi.benchmark.json"
                }
              ],
              "service-name": "saas-reports",
              "stringified-params": true
            },
            "actionLabel": "Save",
            "type": "SUBMIT",
            "identifier": "Submit"
          },
          {
            "actionLabel": "Cancel",
            "type": "CANCEL",
            "identifier": "Cancel"
          }
        ]
      }
    }
  },
  "dashboard_sections": [
    {
      "title": "StarOS BCMCS A11-BC Registration Updates Stats",
      "show_filter": true,
      "widgets": [
        {
          "title": "RP Registration Updates - Transmitted",
          "widget_type": "timeseries",
          "stream": "mobility_kpi_metrics_data",
          "description": "Formula: (%upd-total%) Description: RP Registration Updates - Transmitted",
          "ts_column": "timestamp",
          "max_width": 12,
          "height": 6,
          "min_width": 12,
          "chartProperties": {
            "yAxisLabel": "",
            "xAxisLabel": null,
            "legendLocation": "right",
            "mode": "selection",
            "column-id": "timestamp"
          },
          "interval": "{{INTERVAL}}",
          "series_spec": [
            {
              "column": "kpi_RP_Registration_Updates_Transmitted",
              "agg": "{{FUNCTION}}",
              "type": "int"
            }
          ],
          "extra_filter": "device = '{{DEVICE}}' and schema_key is 'bcmcs'",
          "group_by": [
