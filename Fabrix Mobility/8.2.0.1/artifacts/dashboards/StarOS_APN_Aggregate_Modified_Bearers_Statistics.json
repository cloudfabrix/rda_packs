      "device": "HSTNTXNZ62G"
    },
    "controlPanelFormDefinition": {
      "id": "kpi.benchmark.json",
      "refreshRequired": true,
      "formFieldList": [
        {
          "fieldId": "function",
          "label": "Function",
          "help": "Function",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": "max",
          "lovValues": [
            {
              "identifier": "max",
              "displayName": "Maximum"
            },
            {
              "identifier": "min",
              "displayName": "Minimum"
            },
            {
              "identifier": "avg",
              "displayName": "Average"
            },
            {
              "identifier": "sum",
              "displayName": "Sum"
            }
          ]
        },
        {
          "fieldId": "interval",
          "label": "Interval",
          "help": "Interval",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "defaultValue": null,
          "lovValues": [
            {
              "identifier": "auto",
              "displayName": "Auto"
            },
            {
              "identifier": "5Min",
              "displayName": "5 Minutes"
            },
            {
              "identifier": "15Min",
              "displayName": "15 Minutes"
            },
            {
              "identifier": "1H",
              "displayName": "1 Hour"
            },
            {
              "identifier": "24H",
              "displayName": "1 Day"
            }
          ]
        },
        {
          "fieldId": "device",
          "label": "Device",
          "help": "Device",
          "dataType": "string",
          "hidden": false,
          "editable": true,
          "required": true,
          "controlType": "COMBO_BOX",
          "lovSourceType": "pstream",
          "lovSourceParams": {
            "name": "mobility_kpi_metrics_data",
            "valueColumn": "device",
            "labelColumn": "device",
            "query": "schema_key is 'apn'"
          },
          "defaultValue": "HSTNTXNZ62G"
        }
      ],
      "formActionList": {
        "formActions": [
          {
            "api-endpoint": {
              "methodName": "submitForm",
              "parse-output": false,
              "params": [
                {
                  "formData": {},
                  "formId": "kpi.benchmark.json"
                }
              ],
              "service-name": "saas-reports",
              "stringified-params": true
            },
            "actionLabel": "Save",
            "type": "SUBMIT",
            "identifier": "Submit"
          },
          {
            "actionLabel": "Cancel",
            "type": "CANCEL",
            "identifier": "Cancel"
          }
        ]
      }
    }
  },
