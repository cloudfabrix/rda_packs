{
  "name": "StarOS_APN_Aggregate_Modified_Bearers_Statistics",
  "label": "StarOS APN Aggregate Modified Bearers Statistics",
  "description": "Web report: StarOS APN Aggregate Modified Bearers Statistics",
  "dashboard_folder": "mobility-webreport",
  "enabled": true,
  "stream": "mobility_kpi_metrics_data",
  "dashboard_type": "template",
  "template_variables": {
    "DEVICE": {
      "contextId": "device",
      "default": "HSTNTXNZ62G"
    },
    "FUNCTION": {
      "contextId": "function",
      "default": "max"
    },
    "INTERVAL": {
      "contextId": "interval",
      "default": "auto"
    },
    "ROLLUP": {
      "contextId": "rollup",
      "default": "device"
    },
    "SCHEMA": {
      "contextId": "schema",
      "default": "apn"
    }
  },
  "dashboard_filters": {
    "time_filter": true,
    "default_time_filter_labels": [
      "Last 24 hours"
    ]
  },
  "dynamic_form": {
