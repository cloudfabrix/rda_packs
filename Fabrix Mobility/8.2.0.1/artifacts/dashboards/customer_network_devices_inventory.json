                        "city": {
                            "title": "City",
                            "type": "TEXT",
                            "visible": false
                        },
                        "state": {
                            "title": "State",
                            "type": "TEXT",
                            "visible": false
                        },
                        "country": {
                            "title": "Country",
                            "type": "TEXT",
                            "visible": false
                        },
                        "latitude": {
                            "title": "Location Latitude",
                            "type": "DOUBLE",
                            "visible": false
                        },
                        "longitude": {
                            "title": "Location Longitude",
                            "type": "DOUBLE",
                            "visible": false
                        },
                        "node_id": {
                            "title": "Node ID",
                            "type": "TEXT",
                            "key": true,
                            "visible": false
                        },
                        "last_seen": {
                            "title": "Last Discovery Time",
                            "type": "DATETIME",
                            "visible": true
                        }
                    },
                    "custom_columns": [
                        {
                            "id": "node_id",
                            "label": "Node Id",
                            "expr": "str(_row.node_id).upper()",
                            "hidden": true,
                            "key": true,
                            "visible": false,
                            "sortable": false
                        }
                    ],
                    "actions": [
                        {
                            "permission": "rda:user_dashboard:view",
                            "appName": "user-dashboard/node_details_app",
                            "drillDownLinkField": "hostname",
                            "identifier": "launch.dashboard.device_view_app",
                            "selectionType": "SINGLE",
                            "contextParamList": {
                                "contextParams": [
                                    {
                                        "paramKey": "hostname",
                                        "paramId": "a_asset_name"
                                    },
                                    {
                                        "paramKey": "ip_address",
                                        "paramId": "a_asset_ip_address"
                                    }
                                ]
                            },
                            "title": "Node Details",
                            "type": "GO_TO_APP_STATE"
                        }
                    ],
                    "widget_id": "8ececef3"
                },
                {
                    "title": "Mobility Device Mapping",
                    "widget_type": "tabular",
                    "max_width": 12,
                    "height": 10,
                    "min_width": 12,
                    "stream": "mobility_device_mappings",
                    "ts_column": "timestamp",
                    "virtual_scrolling": true,
                    "remote_searchable0": true,
                    "remote_searchable_cols0": [
                        "device",
                        "ip_address",
                        "network_type"
                    ],
                    "resizableColumns0": [
                        "device"
                    ],
                    "columns": {
                        "device": {
                            "title": "Device",
                            "type": "TEXT",
                            "key": true,
                            "hidden": false
                        },
                        "ip_address": {
                            "title": "IP Address",
                            "type": "TEXT",
                            "key": true,
                            "hidden": false
                        },
                        "image": {
                            "title": "Image",
                            "type": "TEXT",
