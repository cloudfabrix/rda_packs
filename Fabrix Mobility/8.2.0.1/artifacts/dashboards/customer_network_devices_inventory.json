                        },
                        "__uuid": {
                            "title": "UUID ID",
                            "key": true,
                            "visible": false
                        }
                    },
                    "widget_id": "b039e934"
                },
                {
                    "title": "Ports Usage Summary",
                    "widget_type": "tabular",
                    "max_width": 6,
                    "height": 6,
                    "min_width": 6,
                    "showRowSummary": true,
                    "stream": "network-devices-inventory",
                    "ts_column": "timestamp",
                    "duration_hours": 1080,
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "remote_searchable": true,
                    "remote_searchable_cols": [
                        "hostname",
                        "ip_address",
                        "total_up_ports",
                        "total_down_ports",
                        "parent_serial_number",
                        "device_model",
                        "device_location",
                        "serial_number",
                        "equipment_type",
                        "vendor",
                        "additional_ips",
                        "sw_version",
                        "sw_type",
                        "management_ip",
                        "product_family",
                        "equipment_name",
                        "sys_contact",
                        "parent_serial_number"
                    ],
                    "columns": {
                        "hostname": {
                            "title": "Device",
                            "type": "TEXT",
                            "visible": true,
                            "key": true
                        },
                        "ip_address": {
                            "title": "Device IP",
                            "type": "TEXT",
                            "visible": true,
                            "key": true
                        },
                        "parent_serial_number": {
                            "title": "Parent SN",
                            "type": "TEXT",
                            "key": true,
                            "visible": false
                        },
                        "node_id": {
                            "title": "Node ID",
                            "type": "TEXT",
                            "key": true,
                            "visible": false
                        },
                        "org_id": {
                            "title": "Org ID",
                            "type": "TEXT",
                            "key": true,
                            "visible": false,
                            "hidden": true
                        }
                    },
                    "custom_columns": [
                        {
                            "id": "node_id",
                            "label": "Node Id",
                            "expr": "str(_row.node_id).upper()",
                            "hidden": true,
                            "key": true,
                            "visible": false,
                            "sortable": false
                        }
                    ],
                    "pivot": {
                        "pivot_type": "advanced",
                        "group_by": [
                            "hostname",
                            "parent_serial_number",
                            "ip_address"
                        ],
                        "series": [
                            {
                                "column": "total_up_ports",
                                "agg": "sum",
                                "type": "int",
                                "label": "Up Ethernet Ports"
                            },
                            {
                                "column": "total_down_ports",
                                "agg": "sum",
                                "type": "int",
                                "label": "Down Ethernet Ports"
                            },
                            {
                                "column": "total_admin_down_ports",
                                "agg": "sum",
                                "type": "int",
                                "label": "Admin Down Ethernet Ports"
                            },
                            {
                                "column": "total_eth_ports",
                                "agg": "sum",
                                "type": "int",
                                "label": "Total Ethernet Ports"
                            }
                        ]
                    },
                    "actions": [
                        {
                            "permission": "rda:user_dashboard:view",
                            "appName": "user-dashboard/node_details_app",
                            "drillDownLinkField": "hostname",
                            "identifier": "launch.dashboard.device_view_app",
                            "selectionType": "SINGLE",
                            "contextParamList": {
                                "contextParams": [
                                    {
                                        "paramKey": "hostname",
                                        "paramId": "a_asset_name"
                                    },
                                    {
                                        "paramKey": "ip_address",
                                        "paramId": "a_asset_ip_address"
                                    },
                                    {
                                        "paramKey": "ip_address",
                                        "paramId": "ip_address"
                                    },
                                    {
                                        "paramKey": "org_id",
                                        "paramId": "org_id"
                                    }
                                ]
                            },
                            "title": "Node Details",
                            "type": "GO_TO_APP_STATE"
                        }
                    ],
                    "widget_id": "08972f3c"
                },
                {
                    "title": "Interface Summary",
                    "widget_type": "tabular",
                    "max_width": 6,
                    "height": 6,
                    "min_width": 6,
                    "showRowSummary": true,
                    "stream": "network-devices-inventory",
                    "extra_filter": "customer_tag contains '{{CUST_TAG}}' or customer_tag is empty",
                    "ts_column": "timestamp",
                    "duration_hours": 1080,
                    "remote_searchable": true,
                    "remote_searchable_cols": [
                        "vendor",
                        "interface_description"
                    ],
                    "columns": {
                        "vendor": {
                            "title": "Device Vendor",
                            "type": "TEXT",
                            "key": true
                        },
                        "interface_description": {
                            "title": "Interface Label",
                            "type": "TEXT",
                            "key": true
                        },
                        "node_id": {
                            "title": "Node ID",
                            "type": "TEXT",
                            "key": true,
                            "visible": false
                        }
                    },
                    "custom_columns": [
                        {
                            "id": "node_id",
                            "label": "Node Id",
                            "expr": "str(_row.node_id).upper()",
                            "hidden": true,
                            "key": true,
                            "visible": false,
                            "sortable": false
                        }
                    ],
                    "pivot": {
                        "pivot_type": "advanced",
                        "group_by": [
                            "vendor",
                            "interface_description"
                        ],
                        "series": [
                            {
                                "column": "interface_description",
                                "agg": "value_count",
                                "type": "int",
                                "label": "Interface Count"
                            }
                        ]
                    },
                    "actions": [
                        {
                            "permission": "rda:user_dashboard:view",
                            "appName": "user-dashboard/node_details_app",
                            "drillDownLinkField": "hostname",
                            "identifier": "launch.dashboard.device_view_app",
                            "selectionType": "SINGLE",
                            "title": "Node Details",
                            "actionCondition": {
                                "actionControl": "SHOW_IF",
                                "conditionalField": [
                                    {
                                        "conditionType": "IS_NOT_NULL",
                                        "fieldId": "node_id"
                                    }
                                ]
                            },
                            "type": "GO_TO_APP_STATE"
                        }
                    ],
                    "widget_id": "a2064860"
                }
            ]
        }
    ]
