{
    "name": "customer_network_devices_inventory",
    "description": "Network Devices Inventory",
    "label": "Network Devices Inventory - Analytics",
    "enabled": false,
    "dashboard_type": "template",
    "dashboard_style": "auto",
    "version": "26.04.15.1",
    "dashboard_folder": "fabrix-mobility",
    "custom_context": {
        "rda-dashboard-live-edit": true
    },
    "template_variables": {
        "CUST_ID": {
            "contextId": "customerId"
        },
        "PROJ_ID": {
            "contextId": "project_id"
        },
        "PROJ_ID_SINGLE": {
            "contextId": "project_id"
        },
        "CUST_TAG": {
            "contextId": "customerTag"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "extra_filter1": "(project_id is '{{PROJ_ID_SINGLE}}') and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
        "columns_filter": [
            {
                "id": "hostname",
                "label": "Device",
                "type": "TEXT"
            },
            {
                "id": "ip_address",
                "label": "Device IP",
                "type": "TEXT"
            },
            {
                "id": "vendor",
                "label": "Vendor",
                "type": "TEXT"
            },
            {
                "id": "device_model",
                "label": "Device Model",
                "type": "TEXT"
            }
        ],
        "default_time_filter_labels": [
            "Last 24 hours"
        ],
        "group_filters": [
            {
                "stream": "network-devices-inventory",
                "extra_filter": "asset_object in ['CHASSIS','Chassis']",
                "title": "Device",
                "group_by": [
                    "hostname"
                ],
                "ts_column": "timestamp",
                "agg": "value_count",
                "column": "_id",
                "limit": 100,
                "type": "int"
            },
            {
                "stream": "network-devices-inventory",
                "extra_filter": "asset_object in ['CHASSIS','Chassis']",
                "title": "Device IP",
                "group_by": [
                    "ip_address"
                ],
                "ts_column": "timestamp",
                "agg": "cardinality",
                "column": "device_model",
                "limit": 200,
                "type": "int"
            }
        ]
    },
    "dashboard_sections": [
        {
            "title": "Inventory",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Total Devices",
                    "widget_type": "custom_counter",
                    "duration_hours": 1080,
                    "stream": "network-devices-inventory",
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "ts_column": "timestamp",
                    "column": "count_",
                    "agg": "value_count",
                    "type": "int",
                    "min_width": 3,
                    "height": 4,
                    "max_width": 3,
                    "widget_id": "499554e0"
                },
                {
                    "widget_type": "pie_chart",
                    "title": "Devices by Model",
                    "stream": "network-devices-inventory",
                    "ts_column": "timestamp",
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "column": "_id",
                    "agg": "value_count",
                    "group_by": [
                        "device_model"
                    ],
                    "type": "str",
                    "min_width": 3,
                    "height": 4,
                    "max_width": 3,
                    "widget_id": "f29397d2"
                },
                {
                    "title": "Devices by Vendor",
                    "widget_type": "counter",
                    "min_width": 6,
                    "max_width": 6,
                    "height": 3,
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "stream": "network-devices-inventory",
                    "ts_column": "timestamp",
                    "limit": 5,
                    "style": {
                        "color-map": {
                            "ACTIVATED": "#4CAF50",
                            "REACTIVATION_PENDING": " #FF9800",
                            "OFFLINE": " #F44336"
                        }
                    },
                    "duration_hours": 2400,
                    "group_by": [
                        "vendor"
                    ],
                    "column": "_RDA_Id",
                    "agg": "value_count",
                    "type": "str",
                    "widget_id": "dc9dc743"
                },
                {
                    "widget_type": "pie_chart",
                    "title": "Devices By SW Version",
                    "stream": "network-devices-inventory",
                    "ts_column": "timestamp",
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and  (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "column": "_id",
                    "agg": "value_count",
                    "group_by": [
                        "sw_version"
                    ],
                    "type": "str",
                    "min_width": 3,
                    "height": 4,
                    "max_width": 3,
                    "widget_id": "d73d0d8d"
                },
                {
                    "title": "Devices by Model and Version",
                    "widget_type": "multi_bar_chart",
                    "stream": "network-devices-inventory",
                    "ts_column": "timestamp",
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "duration_hours": 1080,
                    "group_by": [
                        "sw_version",
                        "device_model"
                    ],
                    "chartProperties": {
                        "yAxisLabel": "Count",
                        "xAxisLabel": "Model",
                        "stacked": true,
                        "legendLocation": "right",
                        "orientation": "vertical"
                    },
                    "min_width": 9,
                    "height": 4,
                    "max_width": 9,
                    "column": "_id",
                    "agg": "value_count",
                    "widget_id": "b6ae721b"
                },
                {
                    "title": "Devices Details",
                    "widget_type": "tabular",
                    "stream": "network-devices-inventory",
                    "duration_hours": 1080,
                    "extra_filter": "equipment_type in ['CHASSIS','Chassis'] and asset_object is 'Chassis' and (customer_tag is '{{CUST_TAG}}' or customer_tag is empty)",
                    "showRowSummary": true,
                    "query": "*",
                    "min_width": 12,
                    "height": 8,
                    "max_width": 12,
                    "paginated": true,
                    "remote_searchable": true,
                    "remote_searchable_cols": [
                        "hostname",
                        "ip_address",
                        "device_model",
                        "device_location",
                        "serial_number",
                        "equipment_type",
                        "vendor",
                        "additional_ips",
                        "sw_version",
                        "sw_type",
                        "management_ip",
                        "product_family",
                        "equipment_name",
                        "sys_contact",
                        "parent_serial_number"
                    ],
                    "max_rows": 50,
                    "columns": {
                        "hostname": {
                            "title": "Device",
                            "type": "TEXT",
                            "key": true
                        },
                        "product_id": {
                            "title": "Product ID",
                            "type": "TEXT",
                            "visible": false
                        },
                        "shippedc_city": {
                            "title": "Shipped City",
                            "type": "TEXT",
                            "visible": false
                        },
                        "product_family": {
                            "title": "Product Family",
                            "type": "TEXT",
                            "key": true,
                            "visible": false
                        },
                        "ip_address": {
                            "title": "IP Address",
                            "type": "TEXT",
                            "key": true
                        },
                        "org_id": {
                            "title": "Organisation ID",
                            "type": "TEXT",
                            "key": true,
                            "visible": false,
                            "hidden": true
                        },
                        "device_model": "Model",
                        "serial_number": {
                            "title": "Serial Number",
                            "type": "TEXT"
                        },
                        "parent_serial_number": {
                            "title": "Parent SN",
                            "type": "TEXT",
                            "key": true
                        },
                        "vendor": "Vendor",
                        "sw_version": "SW Version",
                        "equipment_type": "Equipment Type",
                        "device_location": {
                            "title": "Location",
                            "visible": false
                        },
                        "sw_type": "Type",
                        "management_ip": "Management IP Address",
                        "additional_ips": {
                            "title": "Device Additional IPs",
                            "defaultWidth": 270,
                            "formatter": "truncate",
                            "visible": false
                        },
                        "equipment_name": {
                            "title": "Equipment Description",
                            "type": "TEXT",
                            "visible": false
                        },
                        "sys_descr": {
                            "title": "SW Version Summary",
                            "type": "TEXT",
                            "visible": false
                        },
                        "sys_contact": {
                            "title": "Contact",
