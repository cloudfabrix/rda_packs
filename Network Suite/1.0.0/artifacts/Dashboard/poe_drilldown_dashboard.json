{
    "name": "poe_drilldown_dashboard",
    "label": "PoE Device Detail (Drill-down)",
    "description": "Opens when user clicks target_ip from a PoE tabular report. Shows counters, gauges, time-series, and PoE charts for the selected device.",
    "dashboard_folder": "Network Device",
    "version": "1.0.0",
    "enabled": true,
    "stream": "rda_snmp_metrics",
    "dashboard_type": "template",
    "dashboard_style": "auto",
    "context_label_id": "target_ip",
    "live_edit": true,
    "template_variables": {
        "DEVICE_IP": {
            "contextId": "target_ip"
        },
        "DEVICE_VENDOR": {
            "contextId": "device_vendor"
        },
        "DEVICE_NAME": {
            "contextId": "sys_name"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "extra_filter": "target_ip is '{{DEVICE_IP}}'",
        "default_time_filter_labels": [
            "Last 24 hours",
            "Last 7 days"
        ],
        "columns_filter": [],
        "group_filters": []
    },
    "dashboard_sections": [
        {
            "title": "PoE Device Detail",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Device Info",
                    "widget_type": "label",
                    "min_width": 12,
                    "max_width": 12,
                    "height": 1,
                    "label": "<h4 style='margin:0;padding:10px;background:#f5f5f5;color:#0066ff;border-radius:4px;text-align:center'>Device Name: {{DEVICE_NAME}} | IP Address: {{DEVICE_IP}} | Vendor: {{DEVICE_VENDOR}}</h4>",
                    "widget_id": "2bb12570"
                },
                {
                    "title": "Total PoE Ports",
                    "widget_type": "counter",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port'",
                    "column": "interface_description",
                    "agg": "cardinality",
                    "type": "int",
                    "style": {
                        "color-list": [
                            "#1e88e5"
                        ]
                    },
                    "min_width": 6,
                    "max_width": 6,
                    "height": 4,
                    "widget_id": "6886e7d5"
                },
                {
                    "title": "Ports In Use",
                    "widget_type": "counter",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_power_consumption > 0",
                    "column": "interface_description",
                    "agg": "cardinality",
                    "type": "int",
                    "style": {
                        "color-list": [
                            "#2E7D32"
                        ]
                    },
                    "min_width": 6,
                    "max_width": 6,
                    "height": 4,
                    "widget_id": "f9e099ac"
                },
                {
                    "title": "",
                    "widget_type0": "gauge_widget",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_usage_percent is not empty and poe_usage_percent > 0 and timestamp is after -10 minutes",
                    "column": "poe_usage_percent",
                    "agg": "avg",
                    "type": "float",
                    "min_width": 6,
                    "max_width": 6,
                    "height": 4,
                    "refreshRequired": true,
                    "label": "Total PoE Usage (%)",
                    "group_by": [
                        "interface_description"
                    ],
                    "chartProperties": {
                        "isSingleZoned": false,
                        "showPointer": true,
                        "pointer": {
                            "length": 85,
                            "strokeWidth": 25,
                            "color": "red"
                        },
                        "minLabel": "0",
                        "maxLabel": "100",
                        "minValue": 0,
                        "maxValue": 100,
                        "arcWidth": 10,
                        "valueFontSize": 30,
                        "bgZonesMode": "percent",
