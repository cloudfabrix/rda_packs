                                "bgColor": "green",
                                "label": "Low"
                            },
                            {
                                "from": 51,
                                "to": 80,
                                "bgColor": "orange",
                                "label": "Medium"
                            },
                            {
                                "from": 81,
                                "to": 100,
                                "bgColor": "red",
                                "label": "High"
                            }
                        ]
                    },
                    "widget_id": "0adb3858"
                },
                {
                    "title": "PoE Power Trend by Interface",
                    "description": "PoE power consumption over time, one line per port (interface_description)",
                    "widget_type": "timeseries",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_power_consumption is > 0",
                    "interval": "auto",
                    "chartProperties": {
                        "yAxisLabel": "Power (W)",
                        "xAxisLabel": "Time",
                        "legendLocation": "right"
                    },
                    "group_by": [
                        "interface_description"
                    ],
                    "series_spec": [
                        {
                            "column": "poe_power_consumption",
                            "agg": "max",
                            "type": "float"
                        }
                    ],
                    "min_width": 6,
                    "max_width": 6,
                    "height": 6,
                    "widget_id": "21294020"
                },
                {
                    "title": "Power Consumption by Interface",
                    "widget_type": "bar_chart",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_power_consumption is not empty and poe_power_consumption > 0",
                    "column": "poe_power_consumption",
                    "agg": "last",
                    "group_by": [
                        "interface_description"
                    ],
                    "type": "float",
                    "chartProperties": {
                        "orientation": "vertical",
                        "xAxisLabel": "Port",
                        "yAxisLabel": "Power (W)"
                    },
                    "min_width": 6,
                    "height": 4,
                    "max_width": 6,
                    "widget_id": "9693eb3e"
                },
                {
                    "title": "PoE Usage % by interface",
                    "widget_type": "bar_chart",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_usage_percent > 0",
                    "column": "poe_usage_percent",
                    "agg": "max",
                    "group_by": [
                        "interface_description"
                    ],
                    "type": "TEXT",
                    "chartProperties": {
                        "orientation": "vertical",
                        "xAxisLabel": "Port",
                        "yAxisLabel": "Usage (%)"
                    },
                    "min_width": 6,
                    "height": 6,
                    "max_width": 6,
                    "widget_id": "ccdcde1a"
                },
                {
                    "title": "Allocated Power by interface",
                    "widget_type": "bar_chart",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and (poe_allocated_power is not empty or poe_available_power is not empty) and poe_allocated_power > 0",
                    "column": "poe_allocated_power",
                    "agg": "last",
                    "group_by": [
                        "interface_description"
                    ],
                    "type": "float",
                    "chartProperties": {
                        "orientation": "vertical",
                        "xAxisLabel": "Port",
                        "yAxisLabel": "Allocated (W)"
                    },
                    "min_width": 6,
                    "height": 6,
                    "max_width": 6,
                    "widget_id": "4b8cf421"
                },
                {
                    "title": "PoE Metrics Details",
                    "widget_type": "tabular",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "duration_hours": 24,
                    "extra_filter": "collection is 'poe_port'",
                    "paginated": true,
                    "max_rows": 50,
                    "columns": {
                        "target_ip": "Target IP",
