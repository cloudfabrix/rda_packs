                                "bgColor": "red",
                                "label": "High"
                            }
                        ]
                    },
                    "widget_id": "552f4ce3"
                },
                {
                    "title": "",
                    "widget_type": "gauge_widget",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and collection is 'poe_port' and poe_power_consumption is not empty and poe_power_consumption > 0 and timestamp is after -10 minutes",
                    "column": "poe_power_consumption",
                    "agg": "avg",
                    "type": "float",
                    "min_width": 6,
                    "max_width": 6,
                    "height": 4,
                    "refreshRequired": true,
                    "label": "Total Power Consumption (W)",
                    "group_by": [
                        "interface_description"
