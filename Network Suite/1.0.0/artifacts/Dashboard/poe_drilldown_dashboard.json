                        "poe_available_power": "Available (W)"
                    },
                    "sort_by": [
                        {
                            "timestamp": "desc"
                        }
                    ],
                    "min_width": 12,
                    "max_width": 12,
                    "height": 6,
                    "widget_id": "c3fa766a"
                }
