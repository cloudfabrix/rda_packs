                    "widget_id": "3128d84b"
                },
                {
                    "title": "Total Ports",
                    "widget_type": "custom_counter",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type is '6' and collection is 'interface' ",
                    "min_width": 4,
                    "max_width": 4,
                    "height": 3,
                    "column": "interface_description",
                    "agg": "cardinality",
                    "type": "str",
                    "style": {
                        "color-list": [
                            "#3f51b5"
                        ]
                    },
                    "widget_id": "f4bb2f63"
                },
                {
                    "title": " Ports up",
                    "widget_type": "custom_counter",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type is  '6' and collection is 'interface' and oper_status_label contains 'Up'",
                    "min_width": 4,
                    "max_width": 4,
                    "height": 3,
                    "column": "interface_description",
                    "agg": "cardinality",
                    "type": "str",
                    "style": {
                        "color-list": [
                            "#3f51b5"
                        ]
                    },
                    "widget_id": "c40bcfe6"
                },
                {
                    "title": " Ports down",
                    "widget_type": "custom_counter",
                    "stream": "rda_snmp_metrics",
                    "ts_column": "timestamp",
                    "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type = '6' and collection is 'interface' and oper_status_label does not contains 'Up'",
                    "min_width": 4,
                    "max_width": 4,
                    "height": 3,
                    "column": "interface_description",
                    "agg": "cardinality",
                    "type": "str",
                    "style": {
