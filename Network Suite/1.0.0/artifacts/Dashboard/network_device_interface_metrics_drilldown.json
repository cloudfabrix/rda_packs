{
    "name": "network_device_interface_metrics_drilldown",
    "description": "Network Device Interface Metrics",
    "label": "Network Device Interface Metrics",
    "enabled": false,
    "dashboard_type": "template",
    "dashboard_style": "auto",
    "dashboard_folder": "Nework Device",
    "context_label_id": "target_ip",
    "live_edit": true,
    "template_variables": {
        "DEVICE_IP": {
            "contextId": "target_ip"
        },
        "DEVICE_VENDOR": {
            "contextId": "device_vendor"
        },
        "DEVICE_NAME": {
            "contextId": "sys_name"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "extra_filter": "target_ip is '{{DEVICE_IP}}'",
        "default_time_filter_labels": [
            "Last 24 hours"
        ],
        "columns_filter": [],
        "group_filters": [
            {
                "stream": "rda_snmp_metrics",
                "title": "Interface Name",
                "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type = '6'",
                "group_by": [
                    "interface_description"
                ],
                "ts_column": "timestamp",
                "agg": "cardinality",
                "column": "interface_description",
                "limit": 250,
                "type": "int"
            },
            {
                "stream": "rda_snmp_metrics",
                "title": "Admin Status",
                "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type = '6'",
                "group_by": [
                    "admin_status_label"
                ],
                "ts_column": "timestamp",
                "agg": "cardinality",
                "column": "admin_status_label",
                "type": "int"
            },
            {
                "stream": "rda_snmp_metrics",
                "title": "Oper Status",
                "extra_filter": "target_ip is '{{DEVICE_IP}}' and interface_type = '6'",
                "group_by": [
                    "oper_status_label"
                ],
                "ts_column": "timestamp",
                "agg": "cardinality",
                "column": "oper_status_label",
                "type": "int"
            }
        ]
    },
    "dashboard_sections": [
        {
            "title": "Interfaces",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Device Info",
                    "widget_type": "label",
                    "min_width": 12,
                    "max_width": 12,
                    "height": 1,
