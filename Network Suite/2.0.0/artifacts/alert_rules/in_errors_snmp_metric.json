{
    "type": "metric",
    "name": "in_errors_snmp_metric",
    "description": "Interface in Errors CFX",
    "enabled": false,
    "schedule": {
        "minutes": 5
    },
    "data": {
        "stream": "rda_snmp_metrics",
        "query": "collection = 'interface' and interface_type = '6' and in_errors >= 0",
        "unique_keys": [
            "target_ip",
            "interface_description",
            "name"
        ],
        "groupby": [
            "target_ip",
            "interface_description",
            "name"
        ],
        "additional_columns": [
            "device_hostname",
            "device_model",
            "device_vendor",
            "in_errors_delta",
            "sys_name"
        ],
        "custom_unique_keys": [],
        "data_transformations": []
    },
    "actions": [
        {
            "state": "OPEN",
            "threshold": "50",
            "agg_column": "in_errors_delta",
            "agg_func": "sum",
            "attributes": {
                "severity": "CRITICAL",
                "metric_name": "in_errors",
                "alert_message": "Critical inbound errors on {{sys_name}} ({{target_ip}}) interface {{interface_description}} (errors={{in_errors_delta}})"
            },
            "notification_profile": "snmp_metrics_notification_profile"
        },
        {
            "state": "CLEAR",
            "agg_column": "in_errors_delta",
            "agg_func": "sum",
            "threshold": "5",
            "attributes": {
                "severity": "INFO",
                "metric_name": "in_errors",
                "alert_message": "Inbound errors cleared on {{sys_name}} ({{target_ip}}) interface {{interface_description}}"
            },
            "notification_profile": "snmp_metrics_notification_profile"
        }
    ],
    "saved_time": "2026-04-15T05:48:29.818873"
}
