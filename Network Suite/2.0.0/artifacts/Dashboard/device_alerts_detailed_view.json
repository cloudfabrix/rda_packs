{
    "name": "device_alerts_detailed_view",
    "label": "Device Alerts",
    "description": "Device Alert Details",
    "dashboard_folder": "FaultAlertsPack",
    "version": "24.03.08.3",
    "enabled": false,
    "dashboard_style": "auto",
    "dashboard_type": "template",
    "custom_context": {
        "rda-dashboard-live-edit": true
    },
    "template_variables": {
        "NODE_ID": {
            "contextId": "unique_id"
        },
        "HOST_OS_IP": {
            "contextId": "host_os_ip"
        },
        "ASSET": {
            "contextId": "host_os_ip"
        },
        "HOST_NAME": {
            "contextId": "hostname"
        },
        "POPULATED_STREAM": {
            "contextId": "populated_stream"
        }
    },
    "dashboard_filters": {
        "time_filter": true,
        "default_time_filter_labels": [
            "Last 1 month"
        ],
        "columns_filter": [
            {
                "id": "a_severity",
                "label": "Severity",
                "type": "TEXT"
            },
            {
                "id": "a_asset_ip_address",
                "label": "Host IP",
                "type": "TEXT"
            },
            {
                "id": "a_message",
                "label": "Message",
                "type": "TEXT"
            },
            {
                "id": "a_status",
                "label": "Alert Status",
                "type": "TEXT"
            },
            {
                "id": "a_asset_name",
                "label": "Asset Name",
                "type": "TEXT"
            },
            {
                "id": "a_ticket_id",
                "label": "Alert ID",
                "type": "TEXT"
            },
            {
                "id": "a_incident_id",
                "label": "Incident ID",
                "type": "TEXT"
            }
        ],
        "group_filters": [
            {
                "stream": "oia-alerts-stream",
                "title": "Source",
                "group_by": [
                    "a_source_systemname"
                ],
                "extend_vars": {
                    "alerts_tabular_extra_filter": " a_source_systemname is not-in 'Alert Group' and a_correlation_status not-in 'AGGREGATE'",
                    "clear_alerts_extra_filter": "a_status is not 'CLEARED' and  a_source_systemname is not-in 'Alert Group' and a_correlation_status not-in 'AGGREGATE'"
                },
                "ts_column": "a_updated_ts",
                "agg": "value_count",
                "column": "a_id",
                "type": "str"
            },
            {
                "stream": "oia-alerts-stream",
                "title": "Monitoring Status",
                "group_by": [
                    "a_status"
                ],
                "ts_column": "a_updated_ts",
                "agg": "value_count",
                "column": "a_id",
                "type": "str"
            },
            {
                "stream": "oia-alerts-stream",
                "title": "Correlation Status",
                "group_by": [
                    "a_correlation_status"
                ],
                "ts_column": "a_updated_ts",
                "agg": "value_count",
                "column": "a_id",
                "type": "str"
            },
            {
                "stream": "oia-alerts-stream",
                "title": "Severity",
                "group_by": [
                    "a_severity"
                ],
                "ts_column": "a_updated_ts",
                "agg": "value_count",
                "column": "a_id",
                "type": "str"
            },
            {
                "stream": "oia-alerts-stream",
                "title": "Policy",
                "group_by": [
                    "a_rule_name"
                ],
                "ts_column": "a_updated_ts",
                "agg": "value_count",
                "column": "a_id",
                "type": "str"
            }
        ]
    },
    "dashboard_sections": [
        {
            "title": "alerts",
            "show_filter": true,
            "projects": [
                "ACME"
            ],
            "widgets": [
                {
                    "extends": [
                        "self:alerts_tabular",
                        "self:actions_lib.alerts_tabular_actions"
                    ],
                    "extend_vars": {
                        "alerts_tabular_extra_filter": " a_source_systemname is not-in 'Alert Group' and a_correlation_status not-in 'AGGREGATE'",
                        "clear_alerts_extra_filter": "a_status is not 'CLEARED' and  a_source_systemname is not-in 'Alert Group' and a_correlation_status not-in 'AGGREGATE'"
                    },
                    "widget_id": "94a3fc11"
                }
            ]
        }
    ],
