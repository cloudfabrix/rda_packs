{
    "name": "customer_SNMP_Traps",
    "label": "SNMP Traps",
    "description": "SNMP traps dashboard",
    "version": "2024.02.27",
    "enabled": true,
    "dashboard_folder": "FaultSnmpPack",
    "dashboard_style": "auto",
    "template_variables": {
        "CUST_ID": {
            "contextId": "customer_id"
        },
        "PROJ_ID": {
            "contextId": "projectId"
        },
        "CUST_TAG": {
            "contextId": "customer_tag"
        }
    },
    "status_poller": {
        "stream": "snmp_trap_events_stream",
        "frequency": 10,
        "columns": [
            "timestamp"
        ],
        "sorting": [
            {
                "timestamp": "desc"
            }
        ],
        "query": "timestamp is after '${timestamp}'",
        "defaults": {
            "timestamp": "$UTCNOW"
        },
        "action": "refresh"
    },
    "dashboard_filters": {
        "default_time_filter_labels": [
            "Last 3 Years"
        ],
        "extra_filter0": "projectId in {{PROJ_ID}}",
        "time_filter": true,
        "columns_filter": [
            {
                "id": "rda_gw_client_ip",
                "label": "Device IP",
                "type": "TEXT"
            },
            {
                "id": "device_hostname",
                "label": "Device Hostname",
                "type": "TEXT"
            },
            {
                "id": "message",
                "label": "Message",
                "type": "TEXT"
            },
            {
                "id": "snmpVersion",
                "label": "SNMP Version",
                "type": "TEXT"
            },
            {
                "id": "device_vendor",
                "label": "Device Vendor",
                "type": "TEXT"
            },
            {
                "id": "device_status",
                "label": "Device Status",
                "type": "TEXT"
            },
            {
                "id": "snmpTrapDescription",
                "label": "MIB Description",
                "type": "TEXT"
            },
            {
                "id": "snmpTrapName",
                "label": "Trap Name",
                "type": "TEXT"
            },
            {
                "id": "device_fw_version",
                "label": "OS Version",
                "type": "TEXT"
            },
            {
                "id": "snmpTrapOID",
                "label": "Trap OID",
                "type": "TEXT"
            },
            {
                "id": "snmpTrapMIB",
                "label": "MIB Name",
                "type": "TEXT"
            }
        ],
        "group_filters": [
            {
                "stream": "syslog_udp_events_stream",
                "title": "Device Vendor",
                "group_by": [
                    "device_vendor"
                ],
                "ts_column": "timestamp",
                "agg": "sum",
                "column": "count_"
            },
            {
                "stream": "syslog_udp_events_stream",
                "title": "Device Model",
                "group_by": [
                    "device_model"
                ],
                "ts_column": "timestamp",
                "agg": "sum",
                "column": "count_"
            },
            {
                "stream": "snmp_trap_events_stream",
                "title": "Device Status",
                "group_by": [
                    "device_status"
                ],
                "ts_column": "timestamp",
                "agg": "sum",
                "column": "count_"
            },
            {
                "stream": "snmp_trap_events_stream",
                "title": "Trap Name",
                "group_by": [
                    "snmpTrapName"
                ],
                "ts_column": "timestamp",
                "agg": "sum",
                "column": "count_"
            },
            {
                "stream": "snmp_trap_events_stream",
                "title": "MIB Name",
                "group_by": [
                    "snmpTrapMIB"
                ],
                "ts_column": "timestamp",
                "agg": "sum",
                "column": "count_"
            }
        ]
    },
    "dashboard_sections": [
        {
            "title": "snmp details",
            "show_filter": true,
            "widgets": [
                {
                    "title": "Total Traps",
                    "widget_type": "custom_counter",
                    "formatter": "DescriptiveCountFormatter",
                    "stream": "snmp_trap_events_stream",
                    "extra_filter0": "projectId in {{PROJ_ID}}",
                    "ts_column": "timestamp",
                    "column": "_id",
                    "agg": "value_count",
                    "type": "int",
                    "max_width": 3,
                    "height": 4,
                    "min_width": 3,
                    "style": {
                        "color-list": [
                            "#215CC3"
                        ]
                    },
                    "widget_id": "df82078f"
                },
                {
                    "title": "By Trap",
                    "widget_type": "pie_chart",
                    "stream": "snmp_trap_events_stream",
                    "extra_filter0": "projectId in {{PROJ_ID}}",
                    "ts_column": "timestamp",
                    "group_by": [
                        "snmpTrapName"
                    ],
                    "column": "count_",
                    "agg": "value_count",
                    "type": "int",
                    "min_width": 5,
                    "height": 4,
                    "max_width": 5,
                    "widget_id": "43799fef"
                },
                {
                    "title": "Traps by IP",
                    "widget_type": "pie_chart",
                    "stream": "snmp_trap_events_stream",
                    "extra_filter": "projectId in {{PROJ_ID}} or projectId is empty",
                    "ts_column": "timestamp",
                    "column": "count_",
                    "agg": "value_count",
                    "group_by": [
                        "rda_gw_client_ip"
                    ],
                    "type": "str",
                    "min_width": 4,
                    "height": 4,
                    "max_width": 8,
                    "widget_id": "5d627f3e"
                },
                {
                    "widget_type": "pie_chart",
                    "title": "Traps by Managed Status",
                    "stream": "snmp_trap_events_stream",
                    "extra_filter": "projectId in {{PROJ_ID}} or projectId is empty",
                    "ts_column": "timestamp",
                    "column": "count_",
                    "agg": "sum",
                    "group_by": [
                        "device_status"
                    ],
                    "min_width": 4,
                    "height": 4,
                    "max_width": 4,
                    "widget_id": "b9f66b8"
                },
                {
                    "widget_type": "pie_chart",
                    "title": "Assets by Managed Status ",
                    "stream": "snmp_trap_events_stream",
                    "extra_filter": "projectId in {{PROJ_ID}} or projectId is empty",
                    "ts_column": "timestamp",
                    "column": "rda_gw_client_ip",
                    "agg": "cardinality",
                    "group_by": [
                        "device_status"
                    ],
                    "min_width": 4,
                    "height": 4,
                    "max_width": 4,
                    "widget_id": "b2266b8"
                },
                {
                    "title": "Unmanaged Devices",
                    "widget_type": "tabular",
                    "max_width": 4,
                    "height": 4,
                    "min_width": 4,
                    "extra_filter": "device_status contains 'UNMANAGED' and (projectId in {{PROJ_ID}} or projectId is empty)",
                    "stream": "snmp_trap_events_stream",
                    "ts_column": "timestamp",
                    "columns": {
                        "rda_gw_client_ip": "IP Address"
                    },
                    "pivot": {
                        "group_by": [
                            "rda_gw_client_ip"
                        ],
                        "column": "count_",
                        "agg": "value_count"
                    },
                    "widget_id": "kz1MoAWD"
                },
                {
                    "title": "SNMP Traps",
                    "widget_type": "tabular",
                    "max_width": 12,
                    "height": 8,
                    "min_width": 12,
                    "stream": "snmp_trap_events_stream",
                    "extra_filter": "projectId in {{PROJ_ID}} or projectId is empty",
                    "ts_column": "timestamp",
                    "resizableColumns": false,
                    "max_rows": 100,
                    "showRowSummary": true,
                    "sorting": [
                        {
                            "timestamp": "desc"
                        }
                    ],
                    "remote_searchable": true,
                    "remote_searchable_cols": [
                        "rda_gw_client_ip",
                        "snmpTrapOID",
                        "device_vendor",
                        "device_status",
                        "snmpTrapMIB",
                        "snmpVersion",
                        "rda_gw_client_ip",
                        "snmpTrapName"
                    ],
                    "columns": {
                        "timestamp": "Timestamp",
                        "rda_gw_client_ip": "Device",
                        "device_hostname": "Device Hostname",
                        "message": "Message",
                        "snmpVersion": "SNMP Version",
                        "device_vendor": "Vendor",
                        "device_status": "Status",
                        "snmpTrapDescription": "MIB Description",
                        "snmpTrapName": "Trap Name",
                        "snmpTrapMIB": "MIB Name",
                        "device_fw_version": "OS Version",
                        "snmpTrapOID": "Trap OID"
                    },
                    "widget_id": "46a6b5b6"
                }
            ]
        }
    ],
    "dashboard_type": "template",
    "dashboard_pages": [],
    "saved_time": "2026-02-10T10:09:41.738939"
}